# ============================================
# CONFIGURAÇÕES DE AMBIENTE
# ============================================
# Copie este arquivo para .env e preencha os valores

# ============================================
# CONTATO E COMUNICAÇÃO
# ============================================

# WhatsApp Business
WHATSAPP_PHONE=5511986532841
WHATSAPP_LINK=https://wa.me/5511986532841

# Email para contato
CONTACT_EMAIL=contato@franfreitas.com.br

# ============================================
# INTEGRAÇÕES DE EMAIL (OPCIONAL)
# ============================================

# EmailJS - Para envio de emails de confirmação
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
# Docs: https://www.emailjs.com

# Gmail SMTP (para backend)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# SendGrid (para backend)
SENDGRID_API_KEY=
# Docs: https://sendgrid.com

# ============================================
# INTEGRAÇÕES DE AGENDAMENTO (OPCIONAL)
# ============================================

# Google Calendar API
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=
# Docs: https://developers.google.com/calendar

# Calendly (embed direto)
CALENDLY_URL=https://calendly.com/seu-usuario

# ============================================
# INTEGRAÇÕES DE DADOS (OPCIONAL)
# ============================================

# Google Sheets API - Para logging de agendamentos
GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=A1
# Docs: https://developers.google.com/sheets

# Firebase (para backend)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ============================================
# REDES SOCIAIS
# ============================================

INSTAGRAM_URL=https://www.instagram.com/dra_franfreitas/
INSTAGRAM_USERNAME=dra_franfreitas
TIKTOK_URL=
FACEBOOK_URL=
YOUTUBE_URL=

# ============================================
# CONFIGURAÇÕES DE SEGURANÇA
# ============================================

# Credenciais de Admin (MUDE EM PRODUÇÃO!)
ADMIN_EMAIL=admin@biomedica.com.br
ADMIN_PASSWORD=Admin123456

# JWT Secret (para backend)
JWT_SECRET=seu_secret_muito_seguro_aqui

# ============================================
# CONFIGURAÇÕES DE APLICAÇÃO
# ============================================

# Environment
NODE_ENV=development
# Valores: development, staging, production

# URL Base
BASE_URL=http://localhost:8000
# Em produção: https://seu-dominio.com.br

# Modo Debug
DEBUG=false

# ============================================
# ANALYTICS (OPCIONAL)
# ============================================

# Google Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Hotjar (Heatmaps)
HOTJAR_SITE_ID=

# Sentry (Error Tracking)
SENTRY_DSN=

# ============================================
# CONFIGURAÇÕES DE PDFs
# ============================================

# Taxa Administrativa Padrão (em %)
PDF_TAX_RATE=10

# Logo para incluir nos PDFs
PDF_LOGO_URL=https://seu-dominio.com.br/img/logo.png

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. NUNCA faça commit do arquivo .env real
# 2. Use .env.example como template
# 3. Defina variáveis sensíveis no servidor
# 4. Em produção, use variáveis de ambiente do seu hosting
